{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TopoSaic",
  "version": "0.2.0",
  "identifier": "com.theatrus.toposaic",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TopoSaic — Terrain Puzzle",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:38787 https://api.github.com https://toposaic.com; img-src 'self' data: https://tile.openstreetmap.org; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4MTAwMjdCRDI5NDM2RDAKUldUUU5wVFNld0lRbU1yNUlmSTU2M3c3Q0NQbjBjNi92V3lqdjZ6ckNBa0lvQkp6eHhiRHgvQ1MK",
      "endpoints": [
        "https://toposaic.com/releases/updater.json",
        "https://github.com/theatrus/toposaic/releases/latest/download/updater.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "GraphicsAndDesign",
    "shortDescription": "TopoSaic creates printable terrain puzzles from real map data.",
    "resources": {
      "../LICENSE": "LICENSE",
      "../NOTICE": "NOTICE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
